{
    "manifest_version": 3,
    "name": "StudyHub Quick Capture",
    "version": "1.0.0",
    "description": "Capture screenshots and save them directly to your StudyHub Notes",
    "permissions": [
        "activeTab",
        "storage",
        "scripting"
    ],
    "host_permissions": [
        "https://personal-dashboard-alpha-gilt.vercel.app/*",
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_title": "StudyHub Quick Capture"
    },
    "background": {
        "service_worker": "background.js"
    },
    "commands": {
        "capture-screenshot": {
            "suggested_key": {
                "default": "Alt+S",
                "mac": "Alt+S"
            },
            "description": "Capture a screenshot"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}